#!/usr/bin/env python3
# gp-tray — a tiny tray indicator for the official GlobalProtect Linux CLI.
#
# GlobalProtect is a trademark of Palo Alto Networks, Inc.
# This project is not affiliated with or endorsed by Palo Alto Networks.

import json
import os
import shutil
import signal
import subprocess
import sys
import threading

import gi

gi.require_version("Gtk", "3.0")
try:
    gi.require_version("AyatanaAppIndicator3", "0.1")
    from gi.repository import AyatanaAppIndicator3 as AppIndicator
except (ValueError, ImportError):
    gi.require_version("AppIndicator3", "0.1")
    from gi.repository import AppIndicator3 as AppIndicator
from gi.repository import Gio, GLib, Gtk

APP_ID = "gp-tray"
VERSION = "0.1.3"
HOMEPAGE = "https://github.com/tiratano/gp-tray"
CONFIG_DIR = os.path.join(GLib.get_user_config_dir(), "gp-tray")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")
POLL_SECONDS = 5
CONNECT_TIMEOUT = 300  # SAML login in a browser can take a while

ICONS = {
    "connected": "gp-tray-connected",
    "connecting": "gp-tray-connecting",
    "disconnecting": "gp-tray-connecting",
    "disconnected": "gp-tray-disconnected",
    "unavailable": "gp-tray-unavailable",
}
STATE_LABELS = {
    "connected": "Connected",
    "connecting": "Connecting…",
    "disconnecting": "Disconnecting…",
    "disconnected": "Not connected",
    "unavailable": "GlobalProtect service unavailable",
}


def load_config():
    try:
        with open(CONFIG_FILE) as f:
            return json.load(f)
    except (OSError, ValueError):
        return {}


def save_config(cfg):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)


def notify(summary, body=""):
    if shutil.which("notify-send"):
        subprocess.Popen(
            ["notify-send", "--app-name", "gp-tray", "--icon", "gp-tray-connected",
             summary, body],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )


def gp_status():
    """Return one of: connected / disconnected / unavailable."""
    if not shutil.which("globalprotect"):
        return "unavailable"
    try:
        out = subprocess.run(
            ["globalprotect", "show", "--status"],
            capture_output=True, text=True, timeout=15, stdin=subprocess.DEVNULL,
        ).stdout.lower()
    except (OSError, subprocess.TimeoutExpired):
        return "unavailable"
    if "cannot connect" in out:
        return "unavailable"
    if "disconnected" in out or "not connected" in out:
        return "disconnected"
    if "connected" in out:
        return "connected"
    return "disconnected"  # e.g. "OnDemand mode." while idle


class GPTray:
    def __init__(self):
        self.cfg = load_config()
        self.state = "disconnected"
        self.busy = False

        self.indicator = AppIndicator.Indicator.new(
            APP_ID, ICONS["disconnected"],
            AppIndicator.IndicatorCategory.APPLICATION_STATUS,
        )
        self.indicator.set_status(AppIndicator.IndicatorStatus.ACTIVE)
        self.indicator.set_title("GlobalProtect (gp-tray)")

        self.menu = Gtk.Menu()
        self.status_item = Gtk.MenuItem(label="Checking status…")
        self.status_item.set_sensitive(False)
        self.connect_item = Gtk.MenuItem(label="Connect…")
        self.connect_item.connect("activate", self.on_connect)
        self.disconnect_item = Gtk.MenuItem(label="Disconnect")
        self.disconnect_item.connect("activate", self.on_disconnect)
        self.restart_item = Gtk.MenuItem(label="Restart GlobalProtect service")
        self.restart_item.connect("activate", self.on_restart_service)
        about_item = Gtk.MenuItem(label="About")
        about_item.connect("activate", self.on_about)
        quit_item = Gtk.MenuItem(label="Quit")
        quit_item.connect("activate", self.on_quit)

        for item in (self.status_item, Gtk.SeparatorMenuItem(),
                     self.connect_item, self.disconnect_item,
                     Gtk.SeparatorMenuItem(), self.restart_item,
                     about_item, quit_item):
            self.menu.append(item)
        self.menu.show_all()
        self.indicator.set_menu(self.menu)
        # Middle-click on the tray icon triggers connect/disconnect.
        self.indicator.set_secondary_activate_target(self.connect_item)

        self.apply_state("disconnected")
        self.poll()
        GLib.timeout_add_seconds(POLL_SECONDS, self.poll)

    # ---------- state / UI ----------

    def apply_state(self, state):
        self.state = state
        self.indicator.set_icon_full(ICONS[state], STATE_LABELS[state])
        self.status_item.set_label(STATE_LABELS[state])
        connected = state == "connected"
        self.connect_item.set_sensitive(not connected and not self.busy)
        self.disconnect_item.set_sensitive(connected and not self.busy)
        self.restart_item.set_sensitive(not self.busy)
        self.indicator.set_secondary_activate_target(
            self.disconnect_item if connected else self.connect_item)

    def poll(self):
        if not self.busy:
            threading.Thread(target=self._poll_worker, daemon=True).start()
        return True  # keep the GLib timer running

    def _poll_worker(self):
        state = gp_status()
        GLib.idle_add(self._poll_done, state)

    def _poll_done(self, state):
        if not self.busy:
            self.apply_state(state)
        return False

    # ---------- actions ----------

    def on_connect(self, _item):
        if self.busy:
            return
        portal = self.ask_portal()
        if not portal:
            return
        self.cfg["portal"] = portal
        save_config(self.cfg)
        self.busy = True
        self.apply_state("connecting")
        notify("Connecting…", f"Portal: {portal}\n"
               "If your portal uses SAML, finish the login in your browser.")
        threading.Thread(target=self._connect_worker, args=(portal,),
                         daemon=True).start()

    def _connect_worker(self, portal):
        try:
            proc = subprocess.run(
                ["globalprotect", "connect", "--portal", portal],
                capture_output=True, text=True, timeout=CONNECT_TIMEOUT,
                stdin=subprocess.DEVNULL,
            )
            output = (proc.stdout + proc.stderr).strip()
        except subprocess.TimeoutExpired:
            output = "Timed out waiting for the connection."
            # Best-effort cleanup so a half-open session doesn't wedge the
            # daemon into rejecting every future connect.
            try:
                subprocess.run(["globalprotect", "disconnect"],
                               capture_output=True, text=True, timeout=30,
                               stdin=subprocess.DEVNULL)
            except (OSError, subprocess.TimeoutExpired):
                pass
        except OSError as e:
            output = str(e)
        GLib.idle_add(self._action_done, "connect", output)

    def on_disconnect(self, _item):
        if self.busy:
            return
        self.busy = True
        self.apply_state("disconnecting")
        threading.Thread(target=self._disconnect_worker, daemon=True).start()

    def _disconnect_worker(self):
        try:
            proc = subprocess.run(
                ["globalprotect", "disconnect"],
                capture_output=True, text=True, timeout=60,
                stdin=subprocess.DEVNULL,
            )
            output = (proc.stdout + proc.stderr).strip()
        except (OSError, subprocess.TimeoutExpired) as e:
            output = str(e)
        GLib.idle_add(self._action_done, "disconnect", output)

    def _action_done(self, action, output):
        self.busy = False
        state = gp_status()
        self.apply_state(state)
        if action == "connect":
            if state == "connected":
                notify("Connected", "Network connection secured.")
            else:
                notify("Connection failed",
                       (output[-260:] or "Unknown error.") + "\n"
                       "Stuck? Try 'Restart GlobalProtect service' in the menu.")
        else:
            notify("Disconnected" if state != "connected" else "Disconnect failed",
                   output[-300:])
        return False

    def on_restart_service(self, _item):
        # Escape hatch for a wedged PanGPS daemon (e.g. stuck believing a
        # tunnel is "already established" and rejecting connect/disconnect).
        if self.busy:
            return
        self.busy = True
        self.status_item.set_label("Restarting GlobalProtect service…")
        self.connect_item.set_sensitive(False)
        self.disconnect_item.set_sensitive(False)
        self.restart_item.set_sensitive(False)
        threading.Thread(target=self._restart_service_worker,
                         daemon=True).start()

    def _restart_service_worker(self):
        errors = []
        cmds = [["systemctl", "--user", "restart", "gpa"]]
        if shutil.which("pkexec"):
            # Root part first: restart the system daemon, then the user agent.
            cmds.insert(0, ["pkexec", "systemctl", "restart", "gpd"])
        else:
            errors.append("pkexec not found — run manually: "
                          "sudo systemctl restart gpd")
        for cmd in cmds:
            try:
                proc = subprocess.run(cmd, capture_output=True, text=True,
                                      timeout=120, stdin=subprocess.DEVNULL)
                if proc.returncode != 0:
                    errors.append((proc.stdout + proc.stderr).strip()
                                  or " ".join(cmd) + " failed")
            except (OSError, subprocess.TimeoutExpired) as e:
                errors.append(str(e))
        GLib.idle_add(self._restart_service_done, errors)

    def _restart_service_done(self, errors):
        self.busy = False
        self.apply_state(gp_status())
        if errors:
            notify("Service restart had problems",
                   "\n".join(errors)[-260:] + "\n"
                   "Manual fix: sudo systemctl restart gpd")
        else:
            notify("GlobalProtect service restarted",
                   "You can try connecting again now.")
        return False

    # ---------- dialogs ----------

    def ask_portal(self):
        # Layout modeled on the classic GlobalProtect welcome popup:
        # big globe, title, hint, entry, full-width accent Connect button.
        dialog = Gtk.Dialog(title="GlobalProtect", modal=True)
        dialog.set_resizable(False)
        dialog.set_default_size(340, -1)

        box = dialog.get_content_area()
        box.set_orientation(Gtk.Orientation.VERTICAL)
        box.set_spacing(12)
        box.set_border_width(24)

        globe = Gtk.Image.new_from_icon_name("gp-tray-connected",
                                             Gtk.IconSize.DIALOG)
        globe.set_pixel_size(96)
        box.pack_start(globe, False, False, 4)

        title = Gtk.Label()
        title.set_markup(
            '<span size="x-large" weight="bold">Welcome to GlobalProtect</span>')
        box.pack_start(title, False, False, 0)

        hint = Gtk.Label(label="Please enter your portal address")
        hint.get_style_context().add_class("dim-label")
        box.pack_start(hint, False, False, 0)

        entry = Gtk.Entry()
        entry.set_text(self.cfg.get("portal", ""))
        entry.set_width_chars(34)
        entry.set_placeholder_text("vpn.example.com")
        entry.set_activates_default(True)
        box.pack_start(entry, False, False, 0)

        button = Gtk.Button(label="Connect")
        button.get_style_context().add_class("suggested-action")
        button.set_can_default(True)
        button.connect("clicked",
                       lambda *_: dialog.response(Gtk.ResponseType.OK))
        box.pack_start(button, False, False, 4)

        dialog.show_all()
        dialog.set_default(button)
        response = dialog.run()
        portal = entry.get_text().strip()
        dialog.destroy()
        return portal if response == Gtk.ResponseType.OK else None

    def on_about(self, _item):
        about = Gtk.AboutDialog(
            program_name="gp-tray",
            version=VERSION,
            comments="Tray indicator for the official GlobalProtect Linux CLI.\n"
                     "GlobalProtect is a trademark of Palo Alto Networks, Inc.\n"
                     "This project is not affiliated with Palo Alto Networks.",
            website=HOMEPAGE,
            license_type=Gtk.License.MIT_X11,
            logo_icon_name="gp-tray-connected",
        )
        about.set_border_width(16)
        about.run()
        about.destroy()

    def on_quit(self, _item):
        # Hide the indicator before exiting so no stale icon lingers.
        self.indicator.set_status(AppIndicator.IndicatorStatus.PASSIVE)
        Gtk.main_quit()


def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    # Single-instance guard: a second launch (e.g. autostart plus a manual
    # run) would leave an orphaned tray icon behind after Quit.
    app = Gio.Application(application_id="io.github.tiratano.gptray")
    app.register()
    if app.get_is_remote():
        print("gp-tray is already running.", file=sys.stderr)
        sys.exit(0)
    GPTray()
    Gtk.main()


if __name__ == "__main__":
    main()
